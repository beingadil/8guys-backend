# MongoDB Connection (Azure Cosmos DB MongoDB API)
# Replace the placeholder with your actual MongoDB connection string
# Format: mongodb+srv://username:password@cluster-name.mongocluster.cosmos.azure.com/?tls=true&authMechanism=SCRAM-SHA-256&retrywrites=false&maxIdleTimeMS=120000
MONGO_URI=

# Alternative variable name (backend checks both)
MONGODB_URI=

# JWT Secret - MUST be set in production!
# Generate a secure random string: openssl rand -base64 32
JWT_SECRET=

# Environment (development or production)
NODE_ENV=development

# Frontend URL (for CORS)
# Leave empty for development - defaults to localhost:5173
FRONTEND_URL=

# Allowed Origins (additional CORS origins)
# Use these for production frontend URLs
ALLOWED_ORIGIN_1=
ALLOWED_ORIGIN_2=
ALLOWED_ORIGIN_3=

# Server Port
# Development: 8080 (default)
# Production: Azure provides process.env.PORT automatically
PORT=8080

# Delivery Settings (optional)
DEFAULT_BRANCH_ID=branch-1
DEFAULT_DELIVERY_FEE=150
DEFAULT_ESTIMATED_TIME=30-45 min

# Admin Account (for seed script - optional)
ADMIN_EMAIL=admin@8guys.com
ADMIN_PASSWORD=
ADMIN_NAME=System Admin
